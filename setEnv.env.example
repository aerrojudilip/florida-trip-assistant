OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-gemini-api-key-here

# Optional defaults for the app's initial configuration
DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=openai

# Optional: fix "YouTube blocked the transcript request" (IpBlocked/RequestBlocked) errors.
# This happens on cloud hosts AND home IPs — YouTube rate-limits by IP reputation, not just
# datacenter ranges. Preferred fix: Webshare (youtube-transcript-api's built-in integration,
# auto-rotates IPs and retries; free tier available at https://www.webshare.io/):
# WEBSHARE_PROXY_USERNAME=
# WEBSHARE_PROXY_PASSWORD=
# Or use any other plain HTTP(S) proxy instead:
# YT_PROXY_URL=
# Or set independently:
# YT_PROXY_HTTP=
# YT_PROXY_HTTPS=

# Optional: fix "Sign in to confirm you're not a bot" errors during yt-dlp metadata
# fetch. Use a throwaway/secondary Google account's cookies, not your main account —
# automated requests carry a small risk of the account being flagged.
# YT_COOKIES_FILE=path/to/cookies.txt
# Or, for local runs only (no browser exists on a cloud host to read from):
# YT_COOKIES_FROM_BROWSER=chrome

# Required to unlock Home, Add Sources, and View Sources (Ask Questions stays public).
APP_PASSWORD=change-me-before-deploying
