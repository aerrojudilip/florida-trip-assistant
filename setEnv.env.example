OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-gemini-api-key-here

# Optional defaults for the app's initial configuration
DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=openai

# Optional: fix "Sign in to confirm you're not a bot" errors — yt-dlp is the PRIMARY
# transcript source (its own caption download, tried before youtube-transcript-api), so
# this also fixes most transcript-blocked errors as a side effect. Use a throwaway/
# secondary Google account's cookies, not your main account — automated requests carry
# a small risk of the account being flagged.
# YT_COOKIES_FILE=path/to/cookies.txt
# Or, for local runs only, with the browser fully CLOSED (an open browser locks its
# cookie database and yt-dlp can't read it):
# YT_COOKIES_FROM_BROWSER=chrome

# Optional: only relevant for videos with no captions at all, where youtube-transcript-api
# is used instead of yt-dlp. In practice, free/trial/static proxies do NOT fix this — we
# tested 10 Webshare static IPs and a Bright Data zone, YouTube/Bright Data blocked every
# one. Only a genuine rotating residential proxy pool works reliably.
# WEBSHARE_PROXY_USERNAME=
# WEBSHARE_PROXY_PASSWORD=
# Or use any other plain HTTP(S) proxy instead:
# YT_PROXY_URL=
# Or set independently:
# YT_PROXY_HTTP=
# YT_PROXY_HTTPS=

# Required to unlock Home, Add Sources, and View Sources (Ask Questions stays public).
APP_PASSWORD=change-me-before-deploying
